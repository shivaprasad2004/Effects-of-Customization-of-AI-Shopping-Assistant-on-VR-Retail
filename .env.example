# =============================================================
# AI-Powered VR Shopping Assistant — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017/vr-retail

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_URI=postgresql://vruser:vrpass@postgres:5432/vrretail
POSTGRES_USER=vruser
POSTGRES_PASSWORD=vrpass
POSTGRES_DB=vrretail

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET=change_me_super_secret_jwt_key_here
JWT_REFRESH_SECRET=change_me_refresh_secret_key_here
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# ── AWS S3 ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=vr-retail-assets
AWS_REGION=us-east-1

# ── Blockchain (Ethereum Sepolia) ────────────────────────────
ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/your_infura_project_id
PRIVATE_KEY=your_wallet_private_key_hex_without_0x
CONTRACT_AUTHENTICITY=0x0000000000000000000000000000000000000001
CONTRACT_PAYMENT=0x0000000000000000000000000000000000000002
CONTRACT_LOYALTY=0x0000000000000000000000000000000000000003

# ── IPFS / Pinata ────────────────────────────────────────────
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET=your_pinata_secret_key

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ── AI Service ───────────────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8000
